{
  "name": "Affiliate",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "Owning user's email — this app's user identity key (same convention as Subscription.owner_email)."
    },
    "code": {
      "type": "string",
      "description": "Unique referral code/slug, e.g. JOHN4F2A."
    },
    "status": {
      "type": "string",
      "enum": ["invited", "active", "suspended"],
      "default": "invited"
    },
    "tier": {
      "type": "number",
      "enum": [1, 2],
      "description": "1 = admin-recruited affiliate. 2 = sub-affiliate recruited by a tier-1 affiliate. No deeper tiers exist."
    },
    "parent_affiliate_id": {
      "type": "string",
      "description": "Affiliate.id of the tier-1 parent. Absent/empty for tier-1 affiliates."
    },
    "commission_pct": {
      "type": "number",
      "description": "Tier-1: admin-set % of sale amount (the pool). Tier-2: % share of the PARENT's pool granted to this sub-affiliate (0-100), not a % of sale."
    },
    "effective_pool_pct": {
      "type": "number",
      "description": "% of sale amount this affiliate personally earns. Tier-1 = commission_pct. Tier-2 = parent.commission_pct × commission_pct / 100. Computed on accept/update, never edited directly."
    },
    "payout_method": {
      "type": "string",
      "enum": ["stripe_connect", "paypal"]
    },
    "payout_account_ref": {
      "type": "string",
      "description": "Stripe Connect account id (acct_...) or PayPal payout email. Never raw bank account/routing numbers."
    },
    "total_earned": {
      "type": "number",
      "default": 0
    },
    "total_paid": {
      "type": "number",
      "default": 0
    },
    "balance_due": {
      "type": "number",
      "default": 0
    }
  },
  "required": ["user_id", "code", "tier"]
}
