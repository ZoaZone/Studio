{
  "name": "AffiliateInvite",
  "type": "object",
  "properties": {
    "inviter_id": {
      "type": "string",
      "description": "Admin user email (tier-1 invites) or the inviting Affiliate.id (tier-2 invites)."
    },
    "email": {
      "type": "string",
      "description": "Invitee's email."
    },
    "proposed_tier": {
      "type": "number",
      "enum": [1, 2]
    },
    "proposed_share_pct": {
      "type": "number",
      "description": "Tier-1: admin-set pool % of sale. Tier-2: % share of the parent's pool (must be ≤ 100 — server-enforced ceiling)."
    },
    "parent_affiliate_id": {
      "type": "string",
      "description": "Set for tier-2 invites only."
    },
    "token": {
      "type": "string",
      "description": "Unguessable acceptance token, included in the invite link."
    },
    "status": {
      "type": "string",
      "enum": ["pending", "accepted", "expired"],
      "default": "pending"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["email", "proposed_tier", "token"]
}
