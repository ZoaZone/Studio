{
  "name": "PayoutBatch",
  "type": "object",
  "properties": {
    "period": {
      "type": "string",
      "description": "e.g. 2026-07"
    },
    "affiliate_id": {
      "type": "string"
    },
    "total_amount": {
      "type": "number"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "processing", "paid", "failed"],
      "default": "pending"
    },
    "provider_ref": {
      "type": "string",
      "description": "Stripe transfer id or PayPal payout batch id."
    },
    "paid_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["affiliate_id", "total_amount"]
}
