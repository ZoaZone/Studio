{
  "name": "Client",
  "type": "object",
  "properties": {
    "agency_id": {
      "type": "string",
      "description": "Reference to Agency"
    },
    "business_name": {
      "type": "string",
      "description": "Client business name"
    },
    "contact_email": {
      "type": "string",
      "description": "Primary contact email"
    },
    "contact_phone": {
      "type": "string",
      "description": "Primary contact phone"
    },
    "website_url": {
      "type": "string",
      "description": "Client website URL"
    },
    "industry": {
      "type": "string",
      "description": "Business industry"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "onboarding",
        "churned"
      ],
      "default": "onboarding"
    },
    "plan_tier": {
      "type": "string",
      "enum": [
        "starter",
        "growth",
        "agency"
      ],
      "default": "starter"
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "required": [
    "business_name"
  ]
}