{
  "name": "Funnel",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "inactive",
        "draft"
      ],
      "default": "draft"
    },
    "total_leads": {
      "type": "number",
      "default": 0
    },
    "converted_leads": {
      "type": "number",
      "default": 0
    },
    "conversion_rate": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}