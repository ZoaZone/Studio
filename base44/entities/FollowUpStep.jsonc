{
  "name": "FollowUpStep",
  "type": "object",
  "properties": {
    "sequence_id": {
      "type": "string"
    },
    "client_id": {
      "type": "string"
    },
    "step_order": {
      "type": "number"
    },
    "delay_hours": {
      "type": "number",
      "default": 0
    },
    "channel": {
      "type": "string",
      "enum": [
        "email",
        "sms",
        "whatsapp"
      ]
    },
    "message_template": {
      "type": "string"
    },
    "media_url": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "paused",
        "completed"
      ],
      "default": "active"
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    }
  },
  "required": [
    "channel"
  ]
}