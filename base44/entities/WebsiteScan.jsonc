{
  "name": "WebsiteScan",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string"
    },
    "website_url": {
      "type": "string"
    },
    "scan_status": {
      "type": "string",
      "enum": [
        "pending",
        "scanning",
        "completed",
        "failed"
      ],
      "default": "pending"
    },
    "pages_scanned": {
      "type": "number",
      "default": 0
    },
    "business_summary": {
      "type": "string"
    },
    "services_found": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "keywords_found": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tone": {
      "type": "string"
    },
    "competitors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scan_at": {
      "type": "string",
      "format": "date-time"
    },
    "raw_data": {
      "type": "string"
    }
  },
  "required": [
    "website_url"
  ]
}