{
  "name": "ScriptTemplate",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "video_script",
        "ad_script",
        "email_sequence",
        "cold_outreach",
        "follow_up",
        "pitch"
      ]
    },
    "platform": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "number"
    },
    "ai_generated": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "title"
  ]
}