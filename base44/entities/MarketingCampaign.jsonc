{
  "name": "MarketingCampaign",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "email",
        "sms",
        "whatsapp",
        "social",
        "multi_channel"
      ],
      "default": "email"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "scheduled",
        "running",
        "completed",
        "paused"
      ],
      "default": "draft"
    },
    "subject": {
      "type": "string"
    },
    "body": {
      "type": "string"
    },
    "media_url": {
      "type": "string"
    },
    "scheduled_at": {
      "type": "string",
      "format": "date-time"
    },
    "sent_count": {
      "type": "number",
      "default": 0
    },
    "open_count": {
      "type": "number",
      "default": 0
    },
    "click_count": {
      "type": "number",
      "default": 0
    },
    "reply_count": {
      "type": "number",
      "default": 0
    }
  },
  "required": [
    "name"
  ]
}