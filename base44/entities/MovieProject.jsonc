{
  "name": "MovieProject",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "genre": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "story_outline": {
      "type": "string",
      "maxLength": 4000,
      "description": "The user's original story idea/prompt (MovieMaker.jsx's storyPrompt)."
    },
    "script": {
      "type": "string",
      "maxLength": 20000,
      "description": "The AI-generated full script, before it's split into scenes."
    },
    "step": {
      "type": "number",
      "default": 0,
      "description": "Wizard step index (0=Story, 1=Reference, 2=Scenes, 3=Voiceover, 4=Music, 5=Export, 6=Dubbing) — resumed on load."
    },
    "scenes": {
      "type": "string",
      "maxLength": 100000,
      "description": "JSON-serialized array of scene objects: {id, text, caption, imageUrl, videoUrl, clips:[{videoUrl,imageUrl,seconds}], voiceUrl, duration, clipDuration, shotsPerScene}. Never includes voiceBlob (a browser-only, non-serializable Blob) — only the durable, uploaded voiceUrl."
    },
    "music_url": {
      "type": "string"
    },
    "title_card_enabled": {
      "type": "boolean",
      "default": true
    },
    "final_video_url": {
      "type": "string",
      "description": "The assembled movie's own URL (Export step's videoUrl), if the project has been assembled at least once."
    },
    "last_saved_at": {
      "type": "string",
      "format": "date-time",
      "description": "Set on every autosave — the sort key for 'most recent project', since it's more reliable than trusting a platform-managed update timestamp to change on every .update() call."
    }
  },
  "required": []
}
