{
  "name": "Commission",
  "type": "object",
  "properties": {
    "subscription_id": {
      "type": "string"
    },
    "plan": {
      "type": "string"
    },
    "sale_amount": {
      "type": "number"
    },
    "affiliate_id": {
      "type": "string"
    },
    "role": {
      "type": "string",
      "enum": ["direct", "override"],
      "description": "direct = the affiliate whose link/code drove the sale. override = the tier-1 parent's cut of a tier-2 sub-affiliate's sale."
    },
    "pct_applied": {
      "type": "number",
      "description": "% of sale_amount this row represents."
    },
    "amount": {
      "type": "number"
    },
    "currency": {
      "type": "string",
      "default": "usd"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "approved", "clawed_back", "paid"],
      "default": "pending"
    },
    "payout_batch_id": {
      "type": "string"
    }
  },
  "required": ["affiliate_id", "role", "amount"]
}
