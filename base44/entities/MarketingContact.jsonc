{
  "name": "MarketingContact",
  "type": "object",
  "properties": {
    "client_id": {
      "type": "string",
      "description": "Reference to Client"
    },
    "full_name": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "whatsapp": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "funnel_stage": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": [
        "website",
        "social",
        "ad",
        "qr_code",
        "referral",
        "manual",
        "import"
      ],
      "default": "manual"
    },
    "lead_score": {
      "type": "number",
      "default": 0
    },
    "opted_in_email": {
      "type": "boolean",
      "default": false
    },
    "opted_in_sms": {
      "type": "boolean",
      "default": false
    },
    "opted_in_whatsapp": {
      "type": "boolean",
      "default": false
    },
    "last_contacted_at": {
      "type": "string",
      "format": "date-time"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "full_name"
  ]
}